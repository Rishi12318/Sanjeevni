# Django Settings
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com

# PostgreSQL Database
POSTGRES_DB=sanjeevni
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# CORS (Frontend URLs) - Add your Vercel frontend URL here
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://sanjeevni-pi.vercel.app

# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Optional: SQLite fallback for local testing (set to 'true' to enable)
USE_SQLITE=false