# ======================================================
# Sanjeevni AI — Environment Variables
# Copy this file to .env.local and fill in the values.
# ======================================================

# ── MongoDB ────────────────────────────────────────────
# Local dev: mongodb://localhost:27017/sanjeevni
# Production: Use a MongoDB Atlas connection string
MONGODB_URI=mongodb://localhost:27017/sanjeevni

# ── Ollama (AI Chat) ───────────────────────────────────
# Local dev: http://localhost:11434
# Production on Vercel: must be a publicly reachable URL
#   e.g. https://ollama.yourserver.com
#   or use ngrok: ngrok http 11434
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
